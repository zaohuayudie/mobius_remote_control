---
import Layout from '../layouts/Layout.astro';
---

<Layout activeNav="home">
	<section class="hero">
		<div class="hero-inner">
			<div class="hero-badge">跨平台远程控制</div>
			<h1 class="hero-title">随时随地<br/>掌控你的设备</h1>
			<p class="hero-desc">
				Mobius 远程控制系统支持 Windows、macOS、Linux 桌面端及 Android、iOS 手机端，
				让你轻松远程访问、操控任何设备，如同身临其境。
			</p>
			<div class="hero-actions">
				<a href="/download" class="btn btn-primary">立即下载</a>
				<a href="/desktop" class="btn btn-outline">了解更多</a>
			</div>
		</div>
		<div class="hero-visual">
			<div class="screen-group">
				<img src="/assets/d1.png" alt="桌面端远程控制" class="screen screen-desktop" />
				<img src="/assets/1.png" alt="手机端远程控制" class="screen screen-mobile" />
			</div>
		</div>
	</section>

	<section class="features">
		<div class="section-inner">
			<h2 class="section-title">核心功能</h2>
			<p class="section-subtitle">强大而简洁的远程控制体验</p>
			<div class="feature-grid">
				<div class="feature-card">
					<div class="feature-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3>远程桌面</h3>
					<p>实时查看并操控远程电脑桌面，低延迟高清画面传输，支持多显示器切换</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
					</div>
					<h3>远程操控</h3>
					<p>完整的键盘鼠标控制，支持触屏手势映射，手机也能精准操控电脑</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
					</div>
					<h3>文件传输</h3>
					<p>设备间快速传输文件，支持拖拽上传下载，断点续传，大文件无忧</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
					</div>
					<h3>手机控制</h3>
					<p>手机远程控制电脑，专为触屏优化的虚拟鼠标和键盘，操作自然流畅</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					</div>
					<h3>安全加密</h3>
					<p>端到端加密传输，设备认证授权，隐私数据不上云，安全无忧</p>
				</div>
				<div class="feature-card">
					<div class="feature-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
					</div>
					<h3>跨平台</h3>
					<p>支持 Windows、macOS、Linux、Android、iOS 全平台，设备互联无障碍</p>
				</div>
			</div>
		</div>
	</section>

	<section class="platforms">
		<div class="section-inner">
			<h2 class="section-title">多端覆盖</h2>
			<p class="section-subtitle">桌面端与手机端，满足不同场景需求</p>
			<div class="platform-cards">
				<a href="/desktop" class="platform-card">
					<div class="platform-icon-wrap desktop">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
					</div>
					<h3>桌面端</h3>
					<p>Windows / macOS / Linux</p>
					<span class="platform-arrow">查看详情 →</span>
				</a>
				<a href="/mobile" class="platform-card">
					<div class="platform-icon-wrap mobile">
						<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
					</div>
					<h3>手机端</h3>
					<p>Android / iOS</p>
					<span class="platform-arrow">查看详情 →</span>
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		max-width: 1200px;
		margin: 0 auto;
		padding: 80px 24px 60px;
		display: flex;
		align-items: center;
		gap: 60px;
	}

	.hero-inner {
		flex: 1;
		min-width: 0;
	}

	.hero-badge {
		display: inline-block;
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(124, 58, 237, 0.1));
		color: var(--color-primary);
		font-size: 14px;
		font-weight: 600;
		padding: 6px 16px;
		border-radius: 20px;
		margin-bottom: 20px;
	}

	.hero-title {
		font-size: 48px;
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.02em;
		background: linear-gradient(135deg, #1e293b 0%, #2563eb 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 20px;
	}

	.hero-desc {
		font-size: 17px;
		line-height: 1.7;
		color: var(--color-text-secondary);
		margin-bottom: 32px;
		max-width: 480px;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 28px;
		font-size: 15px;
		font-weight: 600;
		border-radius: 10px;
		text-decoration: none;
		transition: all 0.2s;
	}

	.btn-primary {
		background: var(--color-primary);
		color: #fff;
		box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
	}

	.btn-primary:hover {
		background: var(--color-primary-dark);
		transform: translateY(-1px);
		box-shadow: 0 6px 16px rgba(37, 99, 235, 0.4);
	}

	.btn-outline {
		border: 1.5px solid var(--color-border);
		color: var(--color-text);
		background: var(--color-surface);
	}

	.btn-outline:hover {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.hero-visual {
		flex: 1;
		min-width: 0;
		display: flex;
		justify-content: center;
	}

	.screen-group {
		position: relative;
		width: 100%;
		max-width: 520px;
	}

	.screen-desktop {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
		border: 1px solid var(--color-border);
	}

	.screen-mobile {
		position: absolute;
		bottom: -20px;
		right: -30px;
		width: 140px;
		border-radius: 12px;
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
		border: 1px solid var(--color-border);
	}

	.section-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 80px 24px;
	}

	.section-title {
		font-size: 32px;
		font-weight: 700;
		text-align: center;
		margin-bottom: 8px;
	}

	.section-subtitle {
		text-align: center;
		color: var(--color-text-secondary);
		font-size: 16px;
		margin-bottom: 48px;
	}

	.features {
		background: var(--color-surface);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.feature-card {
		padding: 28px;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		transition: all 0.2s;
	}

	.feature-card:hover {
		border-color: rgba(37, 99, 235, 0.3);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.feature-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(124, 58, 237, 0.1));
		border-radius: 12px;
		color: var(--color-primary);
		margin-bottom: 16px;
	}

	.feature-card h3 {
		font-size: 18px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.feature-card p {
		font-size: 14px;
		line-height: 1.6;
		color: var(--color-text-secondary);
	}

	.platform-cards {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 24px;
		max-width: 720px;
		margin: 0 auto;
	}

	.platform-card {
		display: block;
		padding: 36px;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		text-decoration: none;
		color: var(--color-text);
		transition: all 0.2s;
	}

	.platform-card:hover {
		border-color: var(--color-primary);
		box-shadow: var(--shadow-lg);
		transform: translateY(-3px);
	}

	.platform-icon-wrap {
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 16px;
		margin-bottom: 20px;
	}

	.platform-icon-wrap.desktop {
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(37, 99, 235, 0.04));
		color: var(--color-primary);
	}

	.platform-icon-wrap.mobile {
		background: linear-gradient(135deg, rgba(124, 58, 237, 0.12), rgba(124, 58, 237, 0.04));
		color: var(--color-accent);
	}

	.platform-card h3 {
		font-size: 22px;
		font-weight: 700;
		margin-bottom: 6px;
	}

	.platform-card p {
		font-size: 14px;
		color: var(--color-text-secondary);
		margin-bottom: 16px;
	}

	.platform-arrow {
		font-size: 14px;
		font-weight: 500;
		color: var(--color-primary);
	}

	@media (max-width: 768px) {
		.hero {
			flex-direction: column;
			padding: 48px 24px 40px;
			gap: 40px;
		}

		.hero-title {
			font-size: 32px;
		}

		.hero-desc {
			font-size: 15px;
		}

		.feature-grid {
			grid-template-columns: 1fr;
		}

		.platform-cards {
			grid-template-columns: 1fr;
		}

		.screen-mobile {
			width: 100px;
			right: -10px;
			bottom: -10px;
		}
	}
</style>
