		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M3 12V6.75l6-1.32v6.48L3 12zm17-9v8.75l-10 .15V5.21L20 3zM3 13l6 .09v6.81l-6-1.15V13zm7 .13L20 13v8l-10-1.79V13.13z"/></svg>`,
		ver: 'Windows 10 / 11',
		size: '约 45 MB',
	},
	{
		name: 'macOS',
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.44-2.83 2.44-1.12 0-1.43-.74-2.67-.74s-1.54.75-2.65.75c-1.14 0-2.06-1.24-2.89-2.47C6.15 16.17 5.3 12.5 7.13 10c.91-1.24 2.36-2 3.83-2 .97 0 1.74.65 2.65.65.88 0 1.76-.65 2.82-.65.91 0 2.1.4 2.87 1.45-2.53 1.6-2.13 5.2.2 6.6zM15.32 4.1c.86-1.04 1.55-2.5 1.32-4.1-1.4.12-2.7.92-3.56 2-.78.92-1.5 2.38-1.24 3.82 1.52.05 2.62-.78 3.48-1.72z"/></svg>`,
		ver: 'macOS 12+',
		size: '约 52 MB',
	},
	{
		name: 'Linux',
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.311.015-.466.046C9.956.3 8.268 1.814 7.896 3.894c-.186 1.04-.056 2.046.326 2.926.17.39.19.82.06 1.224-.322.996-.46 2.046-.396 3.108.068 1.14.4 2.224 1.02 3.14.6.884 1.376 1.4 2.296 1.4h.016c.914 0 1.734-.5 2.296-1.376.62-.916.952-2 1.02-3.14.064-1.062-.074-2.112-.396-3.108-.13-.404-.11-.834.06-1.224.382-.88.512-1.886.326-2.926C15.732 1.814 14.044.3 12.504 0zM4.8 8.6c-1.2.4-2.2 1.4-2.6 2.6-.4 1.2-.2 2.6.6 3.6.4.5.9.1.8 1.8-.2 1-.1 2.2.5 3.2.5.8 1.4 1.2 2.2 1.2h.1c.8 0 1.6-.4 2.2-1.2.6-1 .7-2.2.5-3.2-.1-.7.4-1.3.8-1.8.8-1 1-2.4.6-3.6-.4-1.2-1.4-2.2-2.6-2.6-.6-.2-1.2 0-1.6.4-.4.4-.6 1-.6 1.6v.2c0 .6.2 1.2.6 1.6.4.4 1 .6 1.6.4zm14.4 0c-.6.2-1.2 0-1.6-.4-.4-.4-.6-1-.6-1.6v-.2c0-.6.2-1.2.6-1.6.4-.4 1-.6 1.6-.4 1.2.4 2.2 1.4 2.6 2.6.4 1.2.2 2.6-.6 3.6-.4.5-.9 1.1-.8 1.8.2 1 .1 2.2-.5 3.2-.5.8-1.4 1.2-2.2 1.2h-.1c-.8 0-1.6-.4-2.2-1.2-.6-1-.7-2.2-.5-3.2.1-.7-.4-1.3-.8-1.8-.8-1-1-2.4-.6-3.6.4-1.2 1.4-2.2 2.6-2.6zM8.4 20.4c-.2.8.2 1.6.8 2.2.6.4 1.4.6 2.2.4.8-.2 1.4-.8 1.8-1.6.2-.8-.2-1.6-.8-2.2-.6-.4-1.4-.6-2.2-.4zm7.2 0c-.8-.2-1.6 0-2.2.4-.6.6-1 1.4-.8 2.2.2.8.8 1.4 1.6 1.8.8-.2 1.6-.8 2.2-1.6.2-.8-.2-1.6-.8-2.2-.6-.4-1.4-.6-2.2-.4z"/></svg>`,
		ver: 'Ubuntu / Debian / Fedora',
		size: '约 40 MB',
	},
	{
		name: 'Android',
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 11.48l1.44-2.5c.08-.14.03-.32-.11-.4-.14-.08-.32-.03-.4.11l-1.46 2.53c-1.56-.7-3.3-1.08-5.07-1.08s-3.51.38-5.07 1.08L5.47 8.69c-.08-.14-.26-.19-.4-.11-.14.08-.19.26-.11.4l1.44 2.5C3.28 13.18 1 16.08 1 19.5h22c0-3.42-2.28-6.32-5.4-8.02zM7 17.25c-.69 0-1.25-.56-1.25-1.25s.56-1.25 1.25-1.25 1.25.56 1.25 1.25-.56 1.25-1.25 1.25zm10 0c-.69 0-1.25-.56-1.25-1.25s.56-1.25 1.25-1.25 1.25.56 1.25 1.25-.56 1.25-1.25 1.25z"/></svg>`,
		ver: 'Android 8.0+',
		size: '约 28 MB',
	},
	{
		name: 'iOS',
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.44-2.83 2.44-1.12 0-1.43-.74-2.67-.74s-1.54.75-2.65.75c-1.14 0-2.06-1.24-2.89-2.47C6.15 16.17 5.3 12.5 7.13 10c.91-1.24 2.36-2 3.83-2 .97 0 1.74.65 2.65.65.88 0 1.76-.65 2.82-.65.91 0 2.1.4 2.87 1.45-2.53 1.6-2.13 5.2.2 6.6z"/></svg>`,
		ver: 'iOS 14.0+',
		size: '约 35 MB',
	},
];
---

<Layout title="下载" activeNav="download">
	<section class="page-hero">
		<div class="page-hero-inner">
			<h1>下载 Mobius</h1>
			<p>选择你的平台，下载安装远程控制客户端</p>
		</div>
	</section>

	<section class="download-section">
		<div class="section-inner">
			<div class="download-grid">
				{platforms.map(p => (
					<div class="download-card">
						<div class="download-icon" set:html={p.icon} />
						<h3>{p.name}</h3>
						<div class="download-meta">
							<span class="meta-item">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
								{p.ver}
							</span>
							<span class="meta-item">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
								{p.size}
							</span>
						</div>
						<button class="download-btn">下载安装包</button>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="guide">
		<div class="section-inner">
			<h2 class="section-title">快速上手</h2>
			<div class="steps">
				<div class="step">
					<div class="step-num">1</div>
					<div class="step-content">
						<h3>下载安装</h3>
						<p>选择对应平台下载安装包，按提示完成安装</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">2</div>
					<div class="step-content">
						<h3>注册登录</h3>
						<p>打开应用，注册账号并登录，或使用设备码直接连接</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">3</div>
					<div class="step-content">
						<h3>连接设备</h3>
						<p>输入目标设备码或从设备列表选择，开始远程控制</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.page-hero {
		background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(124, 58, 237, 0.06));
		padding: 64px 24px;
		text-align: center;
	}

	.page-hero-inner {
		max-width: 600px;
		margin: 0 auto;
	}

	.page-hero h1 {
		font-size: 36px;
		font-weight: 800;
		margin-bottom: 12px;
	}

	.page-hero p {
		font-size: 16px;
		color: var(--color-text-secondary);
	}

	.section-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 80px 24px;
	}

	.section-title {
		font-size: 28px;
		font-weight: 700;
		text-align: center;
		margin-bottom: 48px;
	}

	.download-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 20px;
	}

	.download-card {
		text-align: center;
		padding: 32px 20px;
		background: var(--color-surface);
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		transition: all 0.2s;
	}

	.download-card:hover {
		border-color: var(--color-primary);
		box-shadow: var(--shadow-lg);
		transform: translateY(-3px);
	}

	.download-icon {
		color: var(--color-primary);
		margin-bottom: 16px;
	}

	.download-card h3 {
		font-size: 18px;
		font-weight: 700;
		margin-bottom: 12px;
	}

	.download-meta {
		display: flex;
		flex-direction: column;
		gap: 6px;
		margin-bottom: 20px;
	}

	.meta-item {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		font-size: 13px;
		color: var(--color-text-secondary);
	}

	.download-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 10px 24px;
		font-size: 14px;
		font-weight: 600;
		border-radius: 8px;
		border: none;
		background: var(--color-primary);
		color: #fff;
		cursor: pointer;
		transition: all 0.2s;
		width: 100%;
	}

	.download-btn:hover {
		background: var(--color-primary-dark);
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
		max-width: 800px;
		margin: 0 auto;
	}

	.step {
		text-align: center;
	}

	.step-num {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		color: #fff;
		font-size: 20px;
		font-weight: 700;
		border-radius: 50%;
		margin: 0 auto 16px;
	}

	.step-content h3 {
		font-size: 18px;
		font-weight: 600;
		margin-bottom: 8px;
	}

	.step-content p {
		font-size: 14px;
		line-height: 1.6;
		color: var(--color-text-secondary);
	}

	@media (max-width: 768px) {
		.download-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.steps {
			grid-template-columns: 1fr;
		}

		.page-hero h1 {
			font-size: 28px;
		}
	}

	@media (max-width: 480px) {
		.download-grid {
			grid-template-columns: 1fr;
		}
	}
</style>